<?xml version="1.0" encoding="utf-8"?>
<resources>
    <color name="ic_launcher_background">#2995DB</color>
    <color name="splash_background">#2995DB</color>
    <string name="app_name">ApexDeco</string>
    <style name="Theme.ApexDeco" parent="Theme.AppCompat.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>
    <style name="Theme.ApexDeco.Splash" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">@color/splash_background</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>
</resources>